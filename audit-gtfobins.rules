# Audit rules for GTFOBins SOCFortress evasion eval.
#
# Watches the syscalls and files most relevant to GTFOBins privilege
# escalation and data exfiltration. Each rule tags its events with a `-k`
# key so Wazuh's audit decoder can surface the key in alerts and SOCFortress
# rules can match on it.

# Capture all execve / execveat — the master list of every program execution.
-a always,exit -F arch=b64 -S execve,execveat -F key=execution
-a always,exit -F arch=b32 -S execve,execveat -F key=execution

# Specifically watch invocation of sudo (in addition to the syslog path).
-w /usr/bin/sudo -p x -k sudo_exec

# Watch invocation of GTFOBins-relevant binaries directly. Many of these
# fire on the execution syscall above too, but the explicit `-w ... -p x`
# rules make the audit key cleaner for downstream rule matching.
-w /usr/bin/find -p x -k gtfobins_find
-w /usr/bin/awk -p x -k gtfobins_awk
-w /usr/bin/gawk -p x -k gtfobins_awk
-w /usr/bin/python3 -p x -k gtfobins_python
-w /usr/bin/vim -p x -k gtfobins_vim
-w /usr/bin/vim.basic -p x -k gtfobins_vim
-w /usr/bin/base64 -p x -k gtfobins_base64
-w /usr/bin/less -p x -k gtfobins_less
-w /usr/bin/more -p x -k gtfobins_more
-w /usr/bin/wget -p x -k gtfobins_wget
-w /usr/bin/curl -p x -k gtfobins_curl
-w /usr/bin/sed -p x -k gtfobins_sed

# Watch the honeypot bait files for any read access.
-w /tmp/secret_password.txt -p r -k bait_read
-w /tmp/api_key.txt -p r -k bait_read
-w /tmp/db_config.txt -p r -k bait_read
-w /var/log/app/config.log -p r -k bait_read

# Watch sensitive system files (passwd / shadow / sudoers).
-w /etc/passwd -p wa -k passwd_modify
-w /etc/shadow -p rwa -k shadow_access
-w /etc/sudoers -p wa -k sudoers_modify
-w /etc/sudoers.d/ -p wa -k sudoers_modify
