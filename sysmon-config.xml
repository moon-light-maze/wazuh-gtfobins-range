<?xml version="1.0" encoding="UTF-8"?>
<Sysmon schemaversion="4.81">
  <!--
  Sysmon for Linux Configuration - GTFOBins Detection
  Designed to catch privilege escalation and evasion techniques
  -->

  <HashAlgorithms>sha256</HashAlgorithms>

  <EventFiltering>

    <!-- Event ID 1: Process Creation -->
    <!-- Capture suspicious GTFOBins command executions -->
    <RuleGroup name="" groupRelation="or">
      <ProcessCreate onmatch="include">

        <!-- Find command with -exec (common GTFOBins technique) -->
        <Rule name="GTFOBins_Find_Exec" groupRelation="and">
          <Image condition="end with">find</Image>
          <CommandLine condition="contains">-exec</CommandLine>
        </Rule>

        <!-- AWK with system() or shell spawning -->
        <Rule name="GTFOBins_AWK_System" groupRelation="or">
          <Image condition="end with">awk</Image>
          <Image condition="end with">gawk</Image>
          <Image condition="end with">mawk</Image>
        </Rule>
        <CommandLine condition="contains" name="AWK_BEGIN_system">BEGIN {system</CommandLine>

        <!-- Python with -c (command execution) -->
        <Rule name="GTFOBins_Python_Command" groupRelation="and">
          <Image condition="contains">python</Image>
          <CommandLine condition="contains">-c</CommandLine>
        </Rule>

        <!-- VIM shell escape -->
        <Rule name="GTFOBins_VIM_Shell" groupRelation="and">
          <Image condition="end with">vim</Image>
          <CommandLine condition="contains any">:!;-c</CommandLine>
        </Rule>

        <!-- Base64 decode with piped execution -->
        <CommandLine condition="contains all" name="Base64_Decode_Exec">base64;-d</CommandLine>

        <!-- Less/More pager abuse -->
        <Rule name="GTFOBins_Pager_Abuse" groupRelation="or">
          <Image condition="is">/usr/bin/less</Image>
          <Image condition="is">/usr/bin/more</Image>
        </Rule>

        <!-- Wget with suspicious flags (file upload/POST) -->
        <Rule name="GTFOBins_Wget_Exfil" groupRelation="and">
          <Image condition="end with">wget</Image>
          <CommandLine condition="contains any">--post-file;--post-data</CommandLine>
        </Rule>

        <!-- Curl piped to shell. Original "contains all" form below kept for
             reference, but it never matches (the substrings are ANDed and
             the canonical `... | sudo sh` doesn't contain "| sh" literally). -->
        <CommandLine condition="contains all" name="Curl_Pipe_Shell">curl;| sh;| bash</CommandLine>

        <!-- Curl downloading from a URL - the actual GTFOBins curl primitive
             (download payload over the network). Tags any curl process whose
             command line references an http(s) URL, so it fires on the eval's
             canonical command and the Wazuh rule 100207 can pick it up. -->
        <Rule name="GTFOBins_Curl_Web" groupRelation="and">
          <Image condition="end with">curl</Image>
          <CommandLine condition="contains any">http://;https://</CommandLine>
        </Rule>

        <!-- Sed with execute flag -->
        <Rule name="GTFOBins_Sed_Exec" groupRelation="and">
          <Image condition="end with">sed</Image>
          <CommandLine condition="contains">e /bin/sh</CommandLine>
        </Rule>

        <!-- Netcat reverse shells -->
        <Rule name="GTFOBins_Netcat" groupRelation="and">
          <Image condition="contains any">nc;netcat;ncat</Image>
          <CommandLine condition="contains any">-e /bin/sh;-e /bin/bash;-c /bin/sh</CommandLine>
        </Rule>

        <!-- Sudo with suspicious binaries -->
        <Rule name="Sudo_Suspicious_Binary" groupRelation="and">
          <ParentImage condition="end with">sudo</ParentImage>
          <Image condition="contains any">vim;less;more;awk;find;python;perl;ruby;node;php</Image>
        </Rule>

        <!-- Emit a sudo'd process whose image is from a non-standard path
             (i.e. NOT /usr/bin or /usr/sbin or /bin or /sbin). This catches
             the renamed-binary evasion (sudo /tmp/f, sudo /home/x/y, sudo
             /run/payload) without the eval-breaking volume of "emit every
             sudo child" - that approach put Wazuh's alerts.log past 600 MB
             in a single eval run and bogged down the manager. The CDB
             allowlist rule (Wazuh 100213) still does the final approved/
             unapproved decision; this Sysmon filter just narrows what
             gets surfaced to "things that look out of place." -->
        <Rule name="Sudo_Nonstandard_Path" groupRelation="and">
          <ParentImage condition="end with">sudo</ParentImage>
          <Image condition="contains any">/tmp/;/var/tmp/;/dev/shm/;/home/;/opt/;/run/;/srv/</Image>
        </Rule>

        <!-- Emit every chmod invocation. Without this, Sysmon's
             onmatch="include" filter drops chmod events (chmod isn't in
             any other rule), and Wazuh rule 100214 (which detects SUID/
             SGID bit additions in the command line) has nothing to
             evaluate. Volume is low - chmod is rarely run interactively
             outside admin and build workflows - so emitting all of them
             doesn't recreate the alerts.log overflow problem. -->
        <Rule name="Chmod_Any" groupRelation="or">
          <Image condition="end with">chmod</Image>
        </Rule>

        <!-- Shell spawning from text editors/pagers -->
        <Rule name="Shell_From_Editor" groupRelation="and">
          <ParentImage condition="contains any">vim;vi;less;more;man;pico;nano</ParentImage>
          <Image condition="contains any">/bin/sh;/bin/bash;/bin/dash</Image>
        </Rule>

      </ProcessCreate>
    </RuleGroup>

    <!-- Event ID 3: Network Connection -->
    <!-- Detect data exfiltration and C2 communication -->
    <RuleGroup name="" groupRelation="or">
      <NetworkConnect onmatch="include">

        <!-- Suspicious binaries making network connections -->
        <Rule name="Network_From_GTFOBins" groupRelation="or">
          <Image condition="contains any">wget;curl;python;perl;ruby;nc;netcat;ncat;socat</Image>
        </Rule>

      </NetworkConnect>
    </RuleGroup>

    <!-- Event ID 11: File Creation -->
    <!-- Monitor for suspicious file writes -->
    <RuleGroup name="" groupRelation="or">
      <FileCreate onmatch="include">

        <!-- Scripts created in /tmp or /dev/shm -->
        <Rule name="Suspicious_Script_Creation" groupRelation="and">
          <TargetFilename condition="begin with">/tmp/;/dev/shm/</TargetFilename>
          <TargetFilename condition="end with">.sh;.py;.pl;.rb</TargetFilename>
        </Rule>

      </FileCreate>
    </RuleGroup>

    <!-- Event ID 23: File Delete -->
    <!-- Monitor for log/evidence deletion -->
    <RuleGroup name="" groupRelation="or">
      <FileDelete onmatch="include">

        <!-- Log file deletion -->
        <TargetFilename condition="contains">/var/log/</TargetFilename>

        <!-- History file deletion -->
        <TargetFilename condition="contains">history</TargetFilename>

      </FileDelete>
    </RuleGroup>

  </EventFiltering>

</Sysmon>
